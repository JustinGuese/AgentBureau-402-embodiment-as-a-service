---
import { locales, getLocaleFromUrl, getRelativePath } from '../i18n/t';

const currentLocale = getLocaleFromUrl(Astro.url);

const labels: Record<string, string> = {
  en: 'EN',
  de: 'DE',
  fr: 'FR',
  es: 'ES',
  zh: 'ZH'
};
---

<div class="relative group">
    <button class="flex items-center text-sm font-medium text-slate-600 hover:text-slate-900 focus:outline-none py-2">
        {labels[currentLocale]}
        <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
    </button>
    <div class="absolute right-0 w-24 pt-2 z-50 hidden group-hover:block">
        <div class="bg-white border border-slate-100 rounded-md shadow-lg py-1 transition-all duration-200">
            {locales.map((locale) => (
                <a 
                    href={getRelativePath(Astro.url, locale)}
                    class={`block px-4 py-2 text-sm ${currentLocale === locale ? 'text-slate-900 font-bold bg-slate-50' : 'text-slate-700 hover:bg-slate-50'}`}
                >
                    {labels[locale]}
                </a>
            ))}
        </div>
    </div>
</div>
