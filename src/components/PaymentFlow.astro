---
import { getLocaleFromUrl, useTranslations } from '../i18n/t';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<div class="py-12">
	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
		<div class="relative p-6 border border-slate-200 rounded-xl bg-slate-50">
			<div class="absolute -top-4 left-6 bg-slate-900 text-white w-8 h-8 rounded-full flex items-center justify-center font-bold">1</div>
			<h4 class="mt-2 font-bold text-slate-900">{t('home.paymentFlow.step1.title')}</h4>
			<p class="mt-2 text-sm text-slate-600">{t('home.paymentFlow.step1.desc')}</p>
		</div>
		<div class="relative p-6 border border-slate-200 rounded-xl bg-slate-50">
			<div class="absolute -top-4 left-6 bg-slate-900 text-white w-8 h-8 rounded-full flex items-center justify-center font-bold">2</div>
			<h4 class="mt-2 font-bold text-slate-900">{t('home.paymentFlow.step2.title')}</h4>
			<p class="mt-2 text-sm text-slate-600">{t('home.paymentFlow.step2.desc')}</p>
		</div>
		<div class="relative p-6 border border-slate-200 rounded-xl bg-slate-50">
			<div class="absolute -top-4 left-6 bg-slate-900 text-white w-8 h-8 rounded-full flex items-center justify-center font-bold">3</div>
			<h4 class="mt-2 font-bold text-slate-900">{t('home.paymentFlow.step3.title')}</h4>
			<p class="mt-2 text-sm text-slate-600">{t('home.paymentFlow.step3.desc')}</p>
		</div>
		<div class="relative p-6 border border-slate-200 rounded-xl bg-slate-50">
			<div class="absolute -top-4 left-6 bg-slate-900 text-white w-8 h-8 rounded-full flex items-center justify-center font-bold">4</div>
			<h4 class="mt-2 font-bold text-slate-900">{t('home.paymentFlow.step4.title')}</h4>
			<p class="mt-2 text-sm text-slate-600">{t('home.paymentFlow.step4.desc')}</p>
		</div>
	</div>
</div>
