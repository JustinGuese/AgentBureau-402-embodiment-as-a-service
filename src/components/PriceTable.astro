---
import { getLocaleFromUrl, useTranslations } from '../i18n/t';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const pricing = [
	{ service: t('pricing.table.services.invoice'), price: "5.00 USDC", note: t('pricing.table.notes.invoice') },
	{ service: t('pricing.table.services.letter'), price: "3.00 USDC", note: t('pricing.table.notes.letter') },
	{ service: t('pricing.table.services.fax'), price: "1.00 USDC", note: t('pricing.table.notes.fax') },
	{ service: t('pricing.table.services.bankAccount'), price: "500.00 USDC", note: t('pricing.table.notes.bankAccount') },
	{ service: t('pricing.table.services.vatRegister'), price: "500.00 USDC", note: t('pricing.table.notes.vatRegister') },
	{ service: t('pricing.table.services.vatReturn'), price: "100.00 USDC", note: t('pricing.table.notes.vatReturn') },
	{ service: t('pricing.table.services.annualFiling'), price: "200.00 USDC", note: t('pricing.table.notes.annualFiling') },
	{ service: t('pricing.table.services.inkasso'), price: "50.00 USDC", note: t('pricing.table.notes.inkasso') },
	{ service: t('pricing.table.services.euPresence'), price: "5,000.00 USDC", note: t('pricing.table.notes.euPresence') },
	{ service: t('pricing.table.services.vollmacht'), price: "200.00 USDC", note: t('pricing.table.notes.vollmacht') },
	{ service: t('pricing.table.services.vollmachtNotarized'), price: "1,500.00 USDC", note: t('pricing.table.notes.vollmachtNotarized') },
	{ service: t('pricing.table.services.gmbh'), price: "15,500 USDC", note: t('pricing.table.notes.gmbh') },
	{ service: t('pricing.table.services.ug'), price: "1,500+ USDC", note: t('pricing.table.notes.ug') },
];
---

<div class="mt-12 overflow-hidden border border-slate-200 rounded-lg">
	<table class="min-w-full divide-y divide-slate-200">
		<thead class="bg-slate-50">
			<tr>
				<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">{t('pricing.table.service')}</th>
				<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">{t('pricing.table.price')}</th>
				<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">{t('pricing.table.details')}</th>
			</tr>
		</thead>
		<tbody class="bg-white divide-y divide-slate-200">
			{pricing.map((item) => (
				<tr>
					<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900">{item.service}</td>
					<td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600">{item.price}</td>
					<td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">{item.note}</td>
				</tr>
			))}
		</tbody>
	</table>
	<div class="bg-blue-50 px-6 py-4 border-t border-slate-200">
		<p class="text-xs text-blue-800">
			<strong>{t('pricing.table.note')}:</strong> {t('pricing.table.sync')}
		</p>
	</div>
</div>
