      { title: "Pont Fiat/Crypto", description: "Connectez vos revenus en USDC au système bancaire européen traditionnel via une enveloppe corporative légale." },
      { title: "Administration sans intervention", description: "Votre PDG IA gère la comptabilité, les impôts et les dépôts légaux pendant que vous vous concentrez sur le produit." }
    ]
  },
  es: {
    persona: "CEO de E-commerce",
    title: "Agentes CEO de E-commerce IA | AgentBureau",
    description: "Automatice todo su negocio en línea. Forme una empresa, emita facturas y gestione la logística física de forma programática.",
    useCases: [
      { title: "Formación programática", description: "Implemente una entidad legal alemana UG o GmbH para su tienda automatizada en minutos a través de la API.", icon: "🚀" },
      { title: "Cumplimiento global", description: "Calcule automáticamente el IVA de la UE y emita facturas GoBD a clientes internacionales.", icon: "🌍" },
      { title: "Devoluciones físicas", description: "Automatice las etiquetas de devolución y la correspondencia física con los proveedores a través de la API de Carta.", icon: "📦" }
    ],
    benefits: [
      { title: "Escudo corporativo", description: "Proteja sus activos personales envolviendo a su agente de IA en una sociedad de responsabilidad limitada (GmbH/UG)." },
      { title: "Puente Fiat/Crypto", description: "Conecte sus ingresos en USDC con el sistema bancario europeo tradicional a través de una cobertura corporativa legal." },
      { title: "Administración sin intervención", description: "Su CEO de IA se encarga de la contabilidad, los impuestos y las presentaciones legales mientras usted se concentra en el producto." }
    ]
  },
  zh: {
    persona: "电商 CEO",
    title: "AI 电商 CEO 智能体 | AgentBureau",
    description: "使您的整个在线业务自动化。通过程序化方式注册公司、开具发票并管理实体物流。",
    useCases: [
      { title: "程序化注册", description: "通过 API 在几分钟内为您的自动化商店部署合法的德国 UG 或 GmbH 实体。", icon: "🚀" },
      { title: "全球合规", description: "自动计算欧盟增值税并向国际客户开具 GoBD 发票。", icon: "🌍" },
