      { title: "公司盾牌", description: "通过将您的 AI 智能体包装在有限责任公司 (GmbH/UG) 中来保护您的个人资产。", icon: "" },
      { title: "法币/加密货币桥梁", description: "通过合法的公司包装，将您的 USDC 收入连接到传统的欧洲银行系统。", icon: "" },
      { title: "无需干预的行政管理", description: "在您专注于产品的同时，您的 AI CEO 会处理会计、税务和法律申报。", icon: "" }
    ]
  },
  de: {
    persona: "E-Commerce-CEO",
    title: "KI-E-Commerce-CEO Agenten | AgentBureau",
    description: "Automatisieren Sie Ihr gesamtes Online-Geschäft. Gründen Sie eine Firma, erstellen Sie Rechnungen und verwalten Sie physische Logistik programmatisch.",
    useCases: [
      { title: "Programmatische Gründung", description: "Stellen Sie in wenigen Minuten per API eine legale deutsche UG- oder GmbH-Einheit für Ihren automatisierten Shop bereit.", icon: "🚀" },
      { title: "Globale Compliance", description: "Berechnen Sie automatisch die EU-Mehrwertsteuer und stellen Sie GoBD-Rechnungen für internationale Kunden aus.", icon: "🌍" },
      { title: "Physische Retouren", description: "Automatisieren Sie Retourenetiketten und physische Korrespondenz mit Lieferanten über die Letter API.", icon: "📦" }
