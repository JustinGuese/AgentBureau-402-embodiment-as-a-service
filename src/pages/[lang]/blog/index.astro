---
import Landing from '../../../layouts/Landing.astro';
import { locales, useTranslations, defaultLocale } from '../../../i18n/t';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return locales.filter(l => l !== 'en').map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as any;
const t = useTranslations(locale);

const l = (path: string) => {
	if (locale === defaultLocale) return path;
	return `/${locale}${path === '/' ? '' : path}`;
};

// Fetch real posts from collection
const allPosts = await getCollection('blog');

// Group posts by slug to handle translations/fallbacks
const postsBySlug = new Map<string, Record<string, any>>();
allPosts.forEach((post: any) => {
  const slug = post.id.split('/').pop()?.replace(/\.md$/, '') || post.id;
  if (!postsBySlug.has(slug)) postsBySlug.set(slug, {});
  const postLocale = post.data.locale || 'en';
  const slugGroup = postsBySlug.get(slug);
  if (slugGroup) slugGroup[postLocale] = post;
});

// Select the best post for the current locale
const posts = Array.from(postsBySlug.values()).map(translations => {
  return translations[locale] || translations['en'];
}).filter(Boolean);

// Sort by date descending
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Landing title={`${t('blog.metaTitle')} - ${t('site.title')}`}>
  <div class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl font-extrabold text-slate-900 sm:text-5xl">
          {t('blog.title')}
        </h1>
        <p class="mt-4 text-xl text-slate-600">
          {t('blog.subtitle')}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map(post => {
          const slug = post.id.split('/').pop()?.replace(/\.md$/, '') || post.id;
          return (
            <div class="bg-white border border-slate-200 rounded-xl p-6 hover:shadow-md transition-shadow flex flex-col h-full">
              <p class="text-sm text-slate-500 mb-2">
                {post.data.date.toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
              <h2 class="text-xl font-bold text-slate-900 mb-3">{post.data.title}</h2>
              <p class="text-slate-600 mb-4 flex-grow">{post.data.description}</p>
              <a href={l(`/blog/${slug}`)} class="text-slate-900 font-bold hover:underline">
                {t('blog.readMore')} &rarr;
              </a>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</Landing>
