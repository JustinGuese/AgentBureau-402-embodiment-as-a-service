---
import Landing from '../../layouts/Landing.astro';
import Hero from '../../components/Hero.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import PaymentFlow from '../../components/PaymentFlow.astro';
import { locales, useTranslations, getRelativePath, defaultLocale } from '../../i18n/t';

export function getStaticPaths() {
  return locales.filter(l => l !== 'en').map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as any;
const t = useTranslations(locale);

const l = (path: string) => {
	if (locale === defaultLocale) return path;
	return `/${locale}${path === '/' ? '' : path}`;
};
---

<Landing title={t('hero.title')}>
	<Hero 
		title={t('hero.title')}
		subtitle={t('hero.subtitle')}
	/>

	<section class="py-24 bg-slate-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center">
				<h2 class="text-3xl font-extrabold text-slate-900">{t('home.howItWorks.title')}</h2>
				<p class="mt-4 text-lg text-slate-600">{t('home.howItWorks.subtitle')}</p>
			</div>
			<PaymentFlow />
		</div>
	</section>

	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center max-w-3xl mx-auto mb-16">
				<h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
					{t('home.services.title')}
				</h2>
				<p class="mt-4 text-lg text-slate-600">
					{t('home.services.subtitle')}
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
				<ServiceCard 
					title="GmbH Formation"
					description="Register a legal entity for your agent. Complete with digital notary and bank account."
					icon="building"
					href={l('/gmbh-gruenden')}
				/>
				<ServiceCard 
					title="Invoice API"
					description="Issue and receive legally compliant German invoices with automatic VAT calculation."
					icon="invoice"
					href={l('/invoice-api')}
				/>
				<ServiceCard 
					title="Fax API"
					description="The ultimate proof of delivery in Germany. Reach any authority or company via digital fax."
					icon="fax"
					href={l('/fax-api')}
				/>
				<ServiceCard 
					title="Letter API"
					description="Send physical mail via Deutsche Post. Registered mail with return receipt supported."
					icon="mail"
					href={l('/letter-api')}
				/>
			</div>
		</div>
	</section>

	<section class="py-20 bg-slate-900 text-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl font-bold mb-8">{t('home.cta.title')}</h2>
			<div class="flex flex-col sm:flex-row justify-center gap-4">
				<a href="/docs/quickstart" class="px-8 py-3 bg-white text-slate-900 font-semibold rounded-lg hover:bg-slate-100 transition-colors">
					{t('home.cta.docs')}
				</a>
				<a href={l('/playground')} class="px-8 py-3 bg-slate-800 text-white font-semibold rounded-lg hover:bg-slate-700 transition-colors border border-slate-700">
					{t('home.cta.playground')}
				</a>
			</div>
		</div>
	</section>
</Landing>
