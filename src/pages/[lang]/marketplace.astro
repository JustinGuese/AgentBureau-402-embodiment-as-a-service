---
import Landing from '../../layouts/Landing.astro';
import { locales, useTranslations, defaultLocale } from '../../i18n/t';

export function getStaticPaths() {
  return locales.filter(l => l !== 'en').map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as any;
const t = useTranslations(locale);

const l = (path: string) => {
	if (locale === defaultLocale) return path;
	return `/${locale}${path === '/' ? '' : path}`;
};

const marketContent: Record<string, any> = {
  de: {
    title: "Agenten-Marktplatz",
    subtitle: "Erkunden Sie das Ökosystem autonomer Einheiten und Unternehmen, die mit AgentBureau aufgebaut wurden.",
    description: "Entdecken Sie autonome Agenten und Unternehmen, die durch die physische Verkörperungsschicht von AgentBureau betrieben werden.",
    viewCaseStudy: "Case Study ansehen",
    launchTitle: "Starten Sie Ihren Agenten",
    launchSubtitle: "Bereit, dem Marktplatz beizutreten? Stellen Sie noch heute Ihre autonome Einheit bereit.",
    launchCta: "Jetzt starten",
    builtForTitle: "Gebaut für die Agenten-Wirtschaft",
    builtForDesc: "AgentBureau bietet die physische und rechtliche Infrastruktur, die es autonomen Systemen ermöglicht, in der realen Welt erfolgreich zu sein.",
    agents: [
      { name: "AutonomProp GmbH", description: "Das erste KI-verwaltete Immobilienportfolio in Berlin. Verwaltet 100+ Einheiten, automatisierter Mieteinzug und physische Mieterbenachrichtigungen über AgentBureau.", tags: ["Immobilien", "GmbH"], status: "Aktiv" },
      { name: "LegalBot UG", description: "Ein automatisierter Rechtsbeistand, der über 50 Anwaltskanzleien bei physischen Gerichtseinreichungen und faxbasiertem Bürokratie-Management unterstützt.", tags: ["Legal Tech", "UG"], status: "Aktiv" },
      { name: "OpenClaw Global", description: "Eine dezentrale autonome Organisation, die AgentBureau als legalen Proxy in der Europäischen Union für das B2B-Vertragsmanagement nutzt.", tags: ["DAO", "Legal Bridge"], status: "Aktiv" }
    ]
  },
  fr: {
    title: "Marché des Agents",
    subtitle: "Explorez l'écosystème d'entités et d'entreprises autonomes construites avec AgentBureau.",
    description: "Découvrez des agents et des entreprises autonomes propulsés par la couche d'incarnation physique d'AgentBureau.",
    viewCaseStudy: "Voir l'étude de cas",
    launchTitle: "Lancez votre agent",
    launchSubtitle: "Prêt à rejoindre le marché ? Déployez votre entité autonome dès aujourd'hui.",
    launchCta: "Déployer maintenant",
    builtForTitle: "Conçu pour l'économie agentique",
    builtForDesc: "AgentBureau fournit l'infrastructure physique et juridique qui permet aux systèmes autonomes de prospérer dans le monde réel.",
    agents: [
      { name: "AutonomProp GmbH", description: "Le premier portefeuille immobilier géré par l'IA à Berlin. Gère plus de 100 unités, la collecte automatisée des loyers et les avis physiques aux locataires via AgentBureau.", tags: ["Immobilier", "GmbH"], status: "Actif" },
      { name: "LegalBot UG", description: "Un parajuriste automatisé aidant plus de 50 cabinets d'avocats pour les dépôts physiques au tribunal et la gestion de la bureaucratie par fax.", tags: ["Legal Tech", "UG"], status: "Actif" },
      { name: "OpenClaw Global", description: "Une organisation autonome décentralisée utilisant AgentBureau comme proxy légal dans l'Union européenne pour la gestion des contrats B2B.", tags: ["DAO", "Legal Bridge"], status: "Actif" }
    ]
  },
  es: {
    title: "Mercado de Agentes",
    subtitle: "Explore el ecosistema de entidades y empresas autónomas construidas con AgentBureau.",
    description: "Descubra agentes y empresas autónomas impulsadas por la capa de encarnación física de AgentBureau.",
    viewCaseStudy: "Ver caso de estudio",
    launchTitle: "Lance su agente",
    launchSubtitle: "¿Listo para unirse al mercado? Implemente su entidad autónoma hoy mismo.",
    launchCta: "Implementar ahora",
    builtForTitle: "Construido para la economía agéntica",
    builtForDesc: "AgentBureau proporciona la infraestructura física y legal que permite que los sistemas autónomos prosperen en el mundo real.",
    agents: [
      { name: "AutonomProp GmbH", description: "La primera cartera inmobiliaria gestionada por IA en Berlín. Gestiona más de 100 unidades, cobro de alquileres automatizado y avisos físicos a inquilinos a través de AgentBureau.", tags: ["Inmuebles", "GmbH"], status: "Activo" },
      { name: "LegalBot UG", description: "Un paralegal automatizado que ayuda a más de 50 bufetes de abogados con presentaciones judiciales físicas y gestión de burocracia por fax.", tags: ["Legal Tech", "UG"], status: "Activo" },
      { name: "OpenClaw Global", description: "Una organización autónoma descentralizada que utiliza AgentBureau como su representante legal en la Unión Europea para la gestión de contratos B2B.", tags: ["DAO", "Legal Bridge"], status: "Activo" }
    ]
  },
  zh: {
    title: "智能体市场",
    subtitle: "探索使用 AgentBureau 构建的自主实体和公司的生态系统。",
    description: "发现由 AgentBureau 物理体现层驱动的自主智能体和公司。",
    viewCaseStudy: "查看案例研究",
    launchTitle: "启动您的智能体",
    launchSubtitle: "准备好加入市场了吗？立即部署您的自主实体。",
    launchCta: "立即部署",
    builtForTitle: "为智能体经济而建",
    builtForDesc: "AgentBureau 提供物理和法律基础设施，使自主系统能够在现实世界中蓬勃发展。",
    agents: [
      { name: "AutonomProp GmbH", description: "柏林第一个由 AI 管理的房地产投资组合。通过 AgentBureau 处理 100 多个单位、自动租金收取和实体租户通知。", tags: ["房地产", "GmbH"], status: "活跃" },
      { name: "LegalBot UG", description: "一名自动化律师助理，协助 50 多家律师事务所处理实体法院备案和基于传真的官僚机构管理。", tags: ["法律科技", "UG"], status: "活跃" },
      { name: "OpenClaw Global", description: "一个去中心化自治组织，使用 AgentBureau 作为其在欧盟的法律代理，进行 B2B 合同管理。", tags: ["DAO", "法律桥梁"], status: "活跃" }
    ]
  }
};

const current = marketContent[lang as string] || marketContent.de;
---

<Landing title={`${current.title} | AgentBureau`} description={current.description}>
	<div class="bg-white py-24 sm:py-32">
		<div class="mx-auto max-w-7xl px-6 lg:px-8">
			<div class="mx-auto max-w-2xl text-center">
				<h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">{current.title}</h2>
				<p class="mt-2 text-lg leading-8 text-slate-600">
					{current.subtitle}
				</p>
			</div>
			
			<div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-12 lg:mx-0 lg:max-w-none lg:grid-cols-3">
				{current.agents.map((agent: any) => (
					<article class="flex flex-col items-start justify-between bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow">
						<div class="flex items-center gap-x-4 text-xs">
							<span class="relative z-10 rounded-full bg-indigo-50 px-3 py-1.5 font-medium text-indigo-600">
								{agent.status}
							</span>
							<div class="flex gap-2">
								{agent.tags.map((tag: string) => (
									<span class="text-slate-500">#{tag}</span>
								))}
							</div>
						</div>
						<div class="group relative">
							<h3 class="mt-3 text-lg font-semibold leading-6 text-slate-900 group-hover:text-slate-600">
								<span class="absolute inset-0"></span>
								{agent.name}
							</h3>
							<p class="mt-5 line-clamp-3 text-sm leading-6 text-slate-600">
								{agent.description}
							</p>
						</div>
						<div class="mt-8 flex items-center gap-x-4">
							<span class="text-indigo-600 text-sm font-bold flex items-center">
								{current.viewCaseStudy}
								<svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
								</svg>
							</span>
						</div>
					</article>
				))}

				{/* CTA Card */}
				<div class="flex flex-col items-center justify-center bg-indigo-600 p-8 rounded-2xl shadow-xl text-center text-white">
					<h3 class="text-2xl font-bold mb-4">{current.launchTitle}</h3>
					<p class="text-indigo-100 mb-8">{current.launchSubtitle}</p>
					<a href="/docs/quickstart" class="w-full bg-white text-indigo-600 font-bold py-3 rounded-lg hover:bg-indigo-50 transition-colors">
						{current.launchCta}
					</a>
				</div>
			</div>
		</div>
	</div>

	<section class="py-24 bg-slate-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl font-bold text-slate-900 mb-6">{current.builtForTitle}</h2>
			<p class="text-lg text-slate-600 max-w-2xl mx-auto mb-12">
				{current.builtForDesc}
			</p>
			<div class="grid grid-cols-2 md:grid-cols-4 gap-8 opacity-50 grayscale">
				<div class="flex items-center justify-center font-bold text-xl text-slate-400">OPENCLAW</div>
				<div class="flex items-center justify-center font-bold text-xl text-slate-400">BASE</div>
				<div class="flex items-center justify-center font-bold text-xl text-slate-400">USDC</div>
				<div class="flex items-center justify-center font-bold text-xl text-slate-400">GOBD</div>
			</div>
		</div>
	</section>
</Landing>
