---
import Landing from '../layouts/Landing.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import PaymentFlow from '../components/PaymentFlow.astro';
import { getLocaleFromUrl, useTranslations, defaultLocale } from '../i18n/t';

import ComplianceScanner from '../components/ComplianceScanner.tsx';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const l = (path: string) => {
	if (locale === defaultLocale) return path;
	return `/${locale}${path === '/' ? '' : path}`;
};
---

<Landing title={t('hero.title')}>
	<Hero 
		title={t('hero.title')}
		subtitle={t('hero.subtitle')}
	/>

	<section class="py-24 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h2 class="text-3xl font-extrabold text-slate-900">{t('compliance.title')}</h2>
				<p class="mt-4 text-lg text-slate-600">{t('compliance.subtitle')}</p>
			</div>
			<ComplianceScanner 
				client:load 
				title={t('compliance.title')}
				subtitle={t('compliance.subtitle')}
				stepLabel={t('compliance.stepLabel')}
				resultTitle={t('compliance.resultTitle')}
				resultSubtitle={t('compliance.resultSubtitle')}
				ctaText={t('compliance.ctaText')}
				resetText={t('compliance.resetText')}
				questions={t('compliance.questions')}
			/>
		</div>
	</section>

	<section class="py-24 bg-slate-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center">
				<h2 class="text-3xl font-extrabold text-slate-900">{t('home.howItWorks.title')}</h2>
				<p class="mt-4 text-lg text-slate-600">{t('home.howItWorks.subtitle')}</p>
			</div>
			<PaymentFlow />
			
			<div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8">
				<div class="flex flex-col items-center text-center">
					<div class="p-3 bg-blue-100 text-blue-600 rounded-full mb-4">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
						</svg>
					</div>
					<h3 class="font-bold text-slate-900">SIWE Binding</h3>
					<p class="mt-2 text-sm text-slate-600">{t('security.siwe')}</p>
				</div>
				<div class="flex flex-col items-center text-center">
					<div class="p-3 bg-green-100 text-green-600 rounded-full mb-4">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
						</svg>
					</div>
					<h3 class="font-bold text-slate-900">HITL Disclosure</h3>
					<p class="mt-2 text-sm text-slate-600">{t('security.hitl')}</p>
				</div>
				<div class="flex flex-col items-center text-center">
					<div class="p-3 bg-purple-100 text-purple-600 rounded-full mb-4">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
						</svg>
					</div>
					<h3 class="font-bold text-slate-900">AML Compliance</h3>
					<p class="mt-2 text-sm text-slate-600">{t('security.aml')}</p>
				</div>
			</div>
		</div>
	</section>

	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center max-w-3xl mx-auto mb-16">
				<h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
					{t('home.services.title')}
				</h2>
				<p class="mt-4 text-lg text-slate-600">
					{t('home.services.subtitle')}
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
				<ServiceCard 
					title={t('services.gmbh.title').split(' - ')[0]}
					description={t('services.gmbh.description')}
					icon="building"
					href={l('/gmbh-gruenden')}
				/>
				<ServiceCard 
					title={t('services.invoice.title').split(' - ')[0]}
					description={t('services.invoice.description')}
					icon="invoice"
					href={l('/invoice-api')}
				/>
				<ServiceCard 
					title={t('services.fax.title').split(' - ')[0]}
					description={t('services.fax.description')}
					icon="fax"
					href={l('/fax-api')}
				/>
				<ServiceCard 
					title={t('services.letter.title').split(' - ')[0]}
					description={t('services.letter.description')}
					icon="mail"
					href={l('/letter-api')}
				/>
				<ServiceCard 
					title={t('services.banking.title')}
					description={t('services.banking.description')}
					icon="credit-card"
					href="/docs/services/banking"
				/>
				<ServiceCard 
					title={t('services.tax.title')}
					description={t('services.tax.description')}
					icon="document-text"
					href="/docs/services/vat-compliance"
				/>
				<ServiceCard 
					title={t('services.legal.title')}
					description={t('services.legal.description')}
					icon="shield-check"
					href="/docs/services/vollmacht"
				/>
				<ServiceCard 
					title="Marketplace"
					description="Access third-party services via our secure x402 escrow framework."
					icon="shopping-cart"
					href={l('/marketplace')}
				/>
			</div>
		</div>
	</section>

	<section class="py-20 bg-slate-900 text-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl font-bold mb-8">{t('home.cta.title')}</h2>
			<div class="flex flex-col sm:flex-row justify-center gap-4">
				<a href="/docs/quickstart" class="px-8 py-3 bg-white text-slate-900 font-semibold rounded-lg hover:bg-slate-100 transition-colors">
					{t('home.cta.docs')}
				</a>
				<a href="/playground" class="px-8 py-3 bg-slate-800 text-white font-semibold rounded-lg hover:bg-slate-700 transition-colors border border-slate-700">
					{t('home.cta.playground')}
				</a>
			</div>
		</div>
	</section>
</Landing>
