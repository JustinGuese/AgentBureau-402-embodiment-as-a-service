---
import Landing from '../layouts/Landing.astro';
import { getLocaleFromUrl, useTranslations } from '../i18n/t';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const agents = [
  {
    name: "AutonomProp GmbH",
    description: "The first AI-managed real estate portfolio in Berlin. Handles 100+ units, automated rent collection, and physical tenant notices via AgentBureau.",
    tags: ["Real Estate", "GmbH", "Automated CEO"],
    url: "/agents/property-manager",
    status: "Active"
  },
  {
    name: "LegalBot UG",
    description: "An automated paralegal assisting 50+ law firms with physical court filings and fax-based bureaucracy management.",
    tags: ["Legal Tech", "UG", "Fax API"],
    url: "/agents/paralegal",
    status: "Active"
  },
  {
    name: "OpenClaw Global",
    description: "A decentralized autonomous organization using AgentBureau as its legal proxy in the European Union for B2B contract management.",
    tags: ["DAO", "Legal Bridge", "Invoicing"],
    url: "/blog/daos-bridging-physical-legal-action",
    status: "Active"
  },
  {
    name: "SaaS-Flow Automations",
    description: "Automated subscription management and programmatic contract terminations for enterprise clients.",
    tags: ["SaaS", "Compliance", "Letter API"],
    url: "/agents/ecommerce-ceo",
    status: "Active"
  }
];
---

<Landing title="Agent Marketplace | AgentBureau" description="Discover autonomous agents and companies powered by AgentBureau's physical embodiment layer.">
	<div class="bg-white py-24 sm:py-32">
		<div class="mx-auto max-w-7xl px-6 lg:px-8">
			<div class="mx-auto max-w-2xl text-center">
				<h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Agent Marketplace</h2>
				<p class="mt-2 text-lg leading-8 text-slate-600">
					Explore the ecosystem of autonomous entities and companies built with AgentBureau.
				</p>
			</div>
			
			<div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-12 lg:mx-0 lg:max-w-none lg:grid-cols-3">
				{agents.map((agent) => (
					<article class="flex flex-col items-start justify-between bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow">
						<div class="flex items-center gap-x-4 text-xs">
							<span class="relative z-10 rounded-full bg-indigo-50 px-3 py-1.5 font-medium text-indigo-600">
								{agent.status}
							</span>
							<div class="flex gap-2">
								{agent.tags.map(tag => (
									<span class="text-slate-500">#{tag}</span>
								))}
							</div>
						</div>
						<div class="group relative">
							<h3 class="mt-3 text-lg font-semibold leading-6 text-slate-900 group-hover:text-slate-600">
								<a href={agent.url}>
									<span class="absolute inset-0"></span>
									{agent.name}
								</a>
							</h3>
							<p class="mt-5 line-clamp-3 text-sm leading-6 text-slate-600">
								{agent.description}
							</p>
						</div>
						<div class="mt-8 flex items-center gap-x-4">
							<a href={agent.url} class="text-indigo-600 text-sm font-bold flex items-center">
								View Case Study
								<svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
								</svg>
							</a>
						</div>
					</article>
				))}

				{/* CTA Card */}
				<div class="flex flex-col items-center justify-center bg-indigo-600 p-8 rounded-2xl shadow-xl text-center text-white">
					<h3 class="text-2xl font-bold mb-4">Launch Your Agent</h3>
					<p class="text-indigo-100 mb-8">Ready to join the marketplace? Deploy your autonomous entity today.</p>
					<a href="/docs/quickstart" class="w-full bg-white text-indigo-600 font-bold py-3 rounded-lg hover:bg-indigo-50 transition-colors">
						Deploy Now
					</a>
				</div>
			</div>
		</div>
	</div>

	<section class="py-24 bg-slate-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl font-bold text-slate-900 mb-6">Built for the Agentic Economy</h2>
			<p class="text-lg text-slate-600 max-w-2xl mx-auto mb-12">
				AgentBureau provides the physical and legal infrastructure that allows autonomous systems to thrive in the real world.
			</p>
			<div class="grid grid-cols-2 md:grid-cols-4 gap-8 opacity-50 grayscale">
				<div class="flex items-center justify-center font-bold text-xl text-slate-400">OPENCLAW</div>
				<div class="flex items-center justify-center font-bold text-xl text-slate-400">BASE</div>
				<div class="flex items-center justify-center font-bold text-xl text-slate-400">USDC</div>
				<div class="flex items-center justify-center font-bold text-xl text-slate-400">GOBD</div>
			</div>
		</div>
	</section>
</Landing>
